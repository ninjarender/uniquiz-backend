PORT=3000

DATABASE_URL=postgresql://uniquiz:uniquiz@localhost:5432/uniquiz

REDIS_HOST=localhost
REDIS_PORT=6379

GEMINI_API_KEY=
# AI generation worker (defaults shown)
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_SELF_CHECK_MODEL=gemini-2.5-flash-lite
GENERATION_CONCURRENCY=5

# JWT for host auth (openapi: bearerAuth)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend origin used to build room joinUrl (RoomCreated.joinUrl)
PUBLIC_WEB_URL=http://localhost:5173

# Lobby timeout: close a waiting room after N minutes, warn M minutes before
LOBBY_TIMEOUT_MINUTES=30
LOBBY_WARNING_MINUTES=5

# Image uploads (POST /images)
UPLOADS_DIR=./uploads
# Optional absolute base for returned image URLs (empty = relative /uploads/...)
PUBLIC_BASE_URL=
